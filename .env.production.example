APP_ENV=production
APP_TITLE=Perminof
APP_DEBUG=false
API_PREFIX=/api

DATABASE_URL=postgresql+asyncpg://perminof:replace-me@postgres:5432/perminof
DATABASE_ECHO=false

JWT_SECRET_KEY=replace-with-at-least-32-random-bytes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=43200

CELERY_BROKER_URL=amqp://perminof:replace-me@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

POSTGRES_DB=perminof
POSTGRES_USER=perminof
POSTGRES_PASSWORD=replace-me
RABBITMQ_DEFAULT_USER=perminof
RABBITMQ_DEFAULT_PASS=replace-me
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-me
